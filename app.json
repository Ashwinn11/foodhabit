{
  "expo": {
    "name": "Gut Buddy",
    "slug": "foodhabit",
    "owner": "foodhabit",
    "version": "3.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "foodhabit",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "imageWidth": 200,
      "backgroundColor": "#F0F7F2"
    },
    "ios": {
      "supportsTablet": false,
      "requireFullScreen": true,
      "bundleIdentifier": "com.foodhabit.app",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:foodhabit.com"
      ],
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Gut Buddy needs camera access to scan restaurant menus and identify safe dishes for your gut."
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "backgroundColor": "#F0F7F2"
        }
      ],
      "expo-apple-authentication",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Gut Buddy needs camera access to scan restaurant menus."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a729b1be-9c50-4ae8-a28a-96cbe598b18a"
      },
      "SUPABASE_URL": "process.env.EXPO_PUBLIC_SUPABASE_URL",
      "SUPABASE_ANON_KEY": "process.env.EXPO_PUBLIC_SUPABASE_ANON_KEY",
      "REVENUECAT_IOS_API_KEY": "process.env.EXPO_PUBLIC_REVENUECAT_IOS_API_KEY"
    }
  }
}